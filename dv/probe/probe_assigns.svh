assign probe_if.int_registers = dut.de.regfile.register_file;
assign probe_if.wb_halted = `IS_HALT_INSN(dut.ex_wb_if.instruction);
assign probe_if.fe_halted = `IS_HALT_INSN(dut.fe_de_if.instruction);
assign probe_if.clk = dut.clk;
assign probe_if.commit_valid = dut.ex_wb_if.valid;
assign probe_if.wb_rd = dut.wb_de_if.rd;
assign probe_if.wb_rd_value = dut.wb_de_if.result;
assign probe_if.wb_pc = dut.ex_wb_if.pc;
assign probe_if.wb_instruction = dut.ex_wb_if.instruction;
assign probe_if.csr_mstatus = dut.ex.csr_wrapper.csr_mstatus;
assign probe_if.csr_mtvec   = dut.ex.csr_wrapper.csr_mtvec;
assign probe_if.csr_mepc    = dut.ex.csr_wrapper.csr_mepc;
assign probe_if.csr_mcause  = dut.ex.csr_wrapper.csr_mcause;
assign probe_if.csr_mtval   = dut.ex.csr_wrapper.csr_mtval;
